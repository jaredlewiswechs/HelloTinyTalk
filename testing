# 39. HIGHER ORDER FUNCTIONS (passing functions as args)
# ============================================================

# --- Python ---
def apply(func, value):
    return func(value)

result = apply(double, 5)  # 10

def make_greeter(greeting):
    def greeter(name):
        return f"{greeting}, {name}!"
    return greeter

hello = make_greeter("Hello")
print(hello("Jared"))  # "Hello, Jared!"

# --- Ruby ---
def apply(func, value)
  func.call(value)
end

result = apply(double, 5)  # 10

def make_greeter(greeting)
  ->(name) { "#{greeting}, #{name}!" }
end

hello = make_greeter("Hello")
puts hello.call("Jared")  # "Hello, Jared!"

