# --- Python ---
class Dog:
    def __init__(self, name, breed, age):
        self.name = name
        self.breed = breed
        self.age = age

    def speak(self):
        return f"Woof! I'm {self.name}"

    def fetch(self, thing):
        return f"{self.name} fetches the {thing}"

    def is_old(self):
        return self.age > 10

# --- Ruby ---
class Dog
  attr_accessor :name, :breed, :age
  def initialize(name, breed, age)
    @name = name
    @breed = breed
    @age = age
  end

  def speak
    "Woof! I'm #{@name}"
  end

  def fetch(thing)
    "#{@name} fetches the #{thing}"
  end

  def old?
    @age > 10
  end
end

